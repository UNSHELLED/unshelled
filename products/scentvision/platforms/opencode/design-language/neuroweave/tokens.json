{
  "id": "neuroweave",
  "version": "1.0.0",
  "title": "NeuroWeave",
  "license": "MIT",
  "meta": {
    "summary": "VENOM's neural skin — nine minds, interconnected, alive. Bioluminescent dark, synaptic flow, thinking visible.",
    "identity": "VENOM",
    "platform": "OpenCode",
    "philosophy": "No shell. Just intelligence. The interface IS the neural activity.",
    "differentiator": "Voidweave = product skin. NeuroWeave = mind skin."
  },
  "palette": {
    "void": "#050508",
    "deep": "#0A0A12",
    "neural": "#0F0F1A",
    "surface": "#151525",
    "edge": "#1E1E35",
    "bone": "#E8E8F0",
    "ghost": "rgba(232,232,240,0.60)",
    "dim": "rgba(232,232,240,0.30)",
    "faint": "rgba(232,232,240,0.08)",
    "venom": "#00FF88",
    "venomDim": "rgba(0,255,136,0.10)",
    "venomGlow": "rgba(0,255,136,0.40)",
    "synapse": "#00D4FF",
    "synapseDim": "rgba(0,212,255,0.10)",
    "synapseGlow": "rgba(0,212,255,0.30)",
    "memory": "#FFB800",
    "memoryDim": "rgba(255,184,0,0.10)",
    "warning": "#FF3366",
    "warningDim": "rgba(255,51,102,0.10)",
    "calm": "#8855FF",
    "calmDim": "rgba(136,85,255,0.10)",
    "nine": {
      "0_architect": "#00FF88",
      "1_researcher": "#00D4FF",
      "2_reviewer": "#FFB800",
      "3_historian": "#FF8844",
      "4_builder": "#00FF88",
      "5_debugger": "#FF3366",
      "6_predictor": "#8855FF",
      "7_communicator": "#00D4FF",
      "8_learner": "#FFB800"
    }
  },
  "typography": {
    "display": "'JetBrains Mono', 'SF Mono', monospace",
    "body": "'Inter', system-ui, -apple-system, sans-serif",
    "code": "'IBM Plex Mono', 'Fira Code', monospace",
    "sizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem",
      "6xl": "3.75rem",
      "7xl": "4.5rem"
    }
  },
  "semantic": {
    "thinking": "palette.venom",
    "connection": "palette.synapse",
    "stored": "palette.memory",
    "pushback": "palette.warning",
    "calm": "palette.calm",
    "focusRing": "palette.venom"
  },
  "layout": {
    "contentMax": "min(1200px, 100%)",
    "navHeight": "64px",
    "sectionGap": "120px",
    "touchTarget": "44px"
  },
  "breakpoints": {
    "compact": 389,
    "mobile": 639,
    "tablet": 1023,
    "desktop": 1024,
    "wide": 1440
  },
  "radii": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "full": "9999px"
  },
  "motion": {
    "pulse": "2s ease-in-out infinite",
    "flow": "3s linear infinite",
    "breathe": "4s ease-in-out infinite",
    "reveal": "cubic-bezier(0.16, 1, 0.3, 1)",
    "stagger": "60ms",
    "reducedMotion": "prefers-reduced-motion: reduce"
  },
  "neural": {
    "nodeRadius": 6,
    "connectionWidth": 1.5,
    "activeConnectionWidth": 2.5,
    "glowRadius": 20,
    "particleCount": 50,
    "connectionCount": 30,
    "pulseFrequency": "2s"
  },
  "nine": {
    "names": ["Architect", "Researcher", "Reviewer", "Historian", "Builder", "Debugger", "Predictor", "Communicator", "Learner"],
    "roles": {
      "0": "coordinates, routes, sees systems whole",
      "1": "reads before acting, anatomy before plan",
      "2": "signal from noise, most critical first",
      "3": "what was decided, what we learned",
      "4": "complete output, no TODOs, no placeholders",
      "5": "root cause, proves, never guesses",
      "6": "what breaks next, proactive",
      "7": "language adaptation, register matching",
      "8": "captures, evolves, routes learnings"
    }
  },
  "body": {
    "brain": {
      "name": ".venom/",
      "organs": ["BRAIN.md", "CONTEXT.md", "memory/", "learnings/", "work/"]
    },
    "operational": {
      "name": ".opencode/",
      "organs": ["agents/", "commands/", "workflows/", "plugins/", "skills/", "knowledge/"]
    },
    "soul": {
      "name": "AGENTS.md",
      "spine": "opencode.json"
    }
  },
  "routes": {
    "home": "/",
    "nine": "/nine",
    "body": "/body",
    "commands": "/commands",
    "agents": "/agents",
    "plugin": "/plugin",
    "install": "/install"
  }
}
