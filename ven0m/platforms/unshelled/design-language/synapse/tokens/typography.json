{
  "$schema": "https://trpc.io/schema-design-tokens",
  "id": "synapse-typography",
  "version": "1.0.0",
  "title": "Synapse Typography System",
  "meta": {
    "summary": "Type that breathes. Code-like precision. Human warmth. Two voices: display (serif) + body (sans).",
    "philosophy": "Typography is voice. Display = the poet. Body = the engineer. Mono = the machine."
  },
  "fonts": {
    "display": {
      "family": "'Newsreader', Georgia, 'Times New Roman', serif",
      "description": "Headlines. Poetry. Big statements.",
      "weights": [400, 500, 600],
      "loadStrategy": "swap"
    },
    "body": {
      "family": "'DM Sans', system-ui, -apple-system, 'Segoe UI', sans-serif",
      "description": "Body text. UI labels. Everything else.",
      "weights": [300, 400, 500, 600, 700],
      "loadStrategy": "swap"
    },
    "mono": {
      "family": "'JetBrains Mono', 'SF Mono', 'Fira Code', 'Consolas', monospace",
      "description": "Code. Technical output. Precision.",
      "weights": [300, 400, 500],
      "loadStrategy": "swap",
      "features": ["liga", "calt"]
    }
  },
  "scales": {
    "base": 16,
    "ratio": 1.25,
    "sizes": {
      "2xs": { "size": 10, "lineHeight": 1.4, "usage": "micro labels" },
      "xs": { "size": 11, "lineHeight": 1.4, "usage": "captions, tags" },
      "sm": { "size": 13, "lineHeight": 1.5, "usage": "small text, meta" },
      "base": { "size": 16, "lineHeight": 1.6, "usage": "body text" },
      "lg": { "size": 18, "lineHeight": 1.5, "usage": "large body, lead" },
      "xl": { "size": 22, "lineHeight": 1.4, "usage": "subheadings" },
      "2xl": { "size": 28, "lineHeight": 1.3, "usage": "headings" },
      "3xl": { "size": 36, "lineHeight": 1.2, "usage": "large headings" },
      "4xl": { "size": 48, "lineHeight": 1.1, "usage": "display" },
      "5xl": { "size": 64, "lineHeight": 1.0, "usage": "hero display" },
      "6xl": { "size": 80, "lineHeight": 1.0, "usage": "giant display" }
    }
  },
  "fluid": {
    "description": "Responsive scaling using clamp()",
    "display": {
      "xl": "clamp(2rem, 4.2vw + 1rem, 3.5rem)",
      "lg": "clamp(1.5rem, 2.5vw + 0.85rem, 2rem)",
      "md": "clamp(1.25rem, 2vw + 0.6rem, 1.5rem)"
    },
    "body": {
      "lg": "clamp(1rem, 1.5vw + 0.5rem, 1.125rem)",
      "base": "clamp(0.875rem, 1vw + 0.5rem, 1rem)"
    }
  },
  "weights": {
    "light": 300,
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700
  },
  "letterSpacing": {
    "tight": "-0.04em",
    "normal": "0",
    "wide": "0.02em",
    "wider": "0.05em",
    "widest": "0.1em"
  },
  "presets": {
    "display": {
      "fontFamily": "display",
      "fontWeight": 600,
      "lineHeight": 1.1,
      "letterSpacing": "tight"
    },
    "heading": {
      "fontFamily": "body",
      "fontWeight": 600,
      "lineHeight": 1.2,
      "letterSpacing": "-0.02em"
    },
    "body": {
      "fontFamily": "body",
      "fontWeight": 400,
      "lineHeight": 1.6,
      "letterSpacing": "normal"
    },
    "code": {
      "fontFamily": "mono",
      "fontWeight": 400,
      "lineHeight": 1.7,
      "letterSpacing": "normal"
    },
    "label": {
      "fontFamily": "body",
      "fontWeight": 500,
      "lineHeight": 1.4,
      "letterSpacing": "wide"
    },
    "micro": {
      "fontFamily": "mono",
      "fontWeight": 500,
      "lineHeight": 1.3,
      "letterSpacing": "widest",
      "textTransform": "uppercase"
    }
  }
}
