{
  "$schema": "https://trpc.io/schema-design-tokens",
  "id": "synapse-space",
  "version": "1.0.0",
  "title": "Synapse Space System",
  "meta": {
    "summary": "Rhythm through consistent spacing. 4px base. Powers of 2. Neural precision.",
    "philosophy": "Space IS structure. Consistent spacing creates visual rhythm. The eye flows smoothly when spacing follows a predictable scale."
  },
  "base": 4,
  "scale": {
    "0": { "value": 0, "px": "0px", "usage": "no spacing" },
    "px": { "value": 1, "px": "1px", "usage": "hairline, minimal gap" },
    "0.5": { "value": 2, "px": "2px", "usage": "tight spacing, inline elements" },
    "1": { "value": 4, "px": "4px", "usage": "base unit, small gaps" },
    "1.5": { "value": 6, "px": "6px", "usage": "tight list spacing" },
    "2": { "value": 8, "px": "8px", "usage": "compact padding, icon gaps" },
    "2.5": { "value": 10, "px": "10px", "usage": "small component padding" },
    "3": { "value": 12, "px": "12px", "usage": "standard inline spacing" },
    "4": { "value": 16, "px": "16px", "usage": "default component padding" },
    "5": { "value": 20, "px": "20px", "usage": "medium section gaps" },
    "6": { "value": 24, "px": "24px", "usage": "card padding, list items" },
    "7": { "value": 28, "px": "28px", "usage": "section separators" },
    "8": { "value": 32, "px": "32px", "usage": "large section gaps" },
    "9": { "value": 36, "px": "36px", "usage": "panel padding" },
    "10": { "value": 40, "px": "40px", "usage": "major section spacing" },
    "12": { "value": 48, "px": "48px", "usage": "page sections" },
    "14": { "value": 56, "px": "56px", "usage": "large gaps" },
    "16": { "value": 64, "px": "64px", "usage": "hero spacing" },
    "20": { "value": 80, "px": "80px", "usage": "major page divisions" },
    "24": { "value": 96, "px": "96px", "usage": "section headers" },
    "32": { "value": 128, "px": "128px", "usage": "layout major" }
  },
  "semantic": {
    "inline": {
      "xs": { "value": 4, "token": "space.1" },
      "sm": { "value": 8, "token": "space.2" },
      "md": { "value": 12, "token": "space.3" },
      "lg": { "value": 16, "token": "space.4" }
    },
    "inset": {
      "xs": { "value": 4, "token": "space.1" },
      "sm": { "value": 8, "token": "space.2" },
      "md": { "value": 16, "token": "space.4" },
      "lg": { "value": 24, "token": "space.6" },
      "xl": { "value": 32, "token": "space.8" }
    },
    "stack": {
      "xs": { "value": 4, "token": "space.1" },
      "sm": { "value": 8, "token": "space.2" },
      "md": { "value": 16, "token": "space.4" },
      "lg": { "value": 24, "token": "space.6" },
      "xl": { "value": 32, "token": "space.8" }
    }
  },
  "layout": {
    "sidebarWidth": { "value": 280, "px": "280px" },
    "sidebarCollapsedWidth": { "value": 64, "px": "64px" },
    "headerHeight": { "value": 56, "px": "56px" },
    "footerHeight": { "value": 48, "px": "48px" },
    "maxContentWidth": { "value": 1200, "px": "1200px" },
    "modalMaxWidth": { "value": 560, "px": "560px" }
  }
}
